{
  "version": "1.0",
  "sources": ["models/"],
  "outputDirectory": "sdk",
  "maven": {
    "dependencies": [
      "software.amazon.smithy:smithy-openapi:1.55.0",
      "software.amazon.smithy:smithy-aws-traits:1.55.0",
      "software.amazon.smithy.typescript:smithy-aws-typescript-codegen:0.22.0",
      "software.amazon.smithy.python.codegen:core:0.3.0"
    ]
  },
  "projections": {
    "typescript": {
      "plugins": {
        "typescript-client-codegen": {
          "service": "com.hyperswitch#Hyperswitch",
          "package": "@juspay/hyperswitch-client",
          "packageVersion": "0.1.0"
        }
      }
    },
    "python": {
      "plugins": {
        "python-client-codegen": {
          "service": "com.hyperswitch#Hyperswitch",
          "module": "hyperswitch_client",
          "moduleVersion": "0.1.0"
        }
      }
    }
  }
}
