  "bpWithPayoutLinkNoDomains": {
    "payout_link_config": {
      "domain_name": "checkout.example.com",
      "allowed_domains": [],
      "ui_config": {
        "logo": "https://example.com/logo.png",
        "merchant_name": "Test Merchant",
        "theme": "#4285F4"
      },
      "form_layout": "tabs",
      "payout_test_mode": false
